# ─────────────────────────────────────────────────────────────────────────────
# CloudKitchen ONE — frontend environment
# Copy this file to `.env` (or `.env.local`).
# NOTE: Vite bakes these in at BUILD time — rebuild / redeploy after changing them.
# ─────────────────────────────────────────────────────────────────────────────

# Absolute backend API origin.
#   • Local dev: leave EMPTY to use the Vite dev proxy (see `vite.config.ts`),
#     which forwards /api/* to your local backend (default http://localhost:5003).
#   • Production: set to the deployed backend origin,
#     e.g. https://ckitchenbackend.onrender.com
VITE_API_URL=

# Fallback alias — used only if VITE_API_URL is empty. Same meaning as above.
VITE_API_PROXY_TARGET=
